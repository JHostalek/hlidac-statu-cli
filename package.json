{
  "name": "@jhostalek/hlidac-statu-cli",
  "version": "0.2.0",
  "description": "CLI wrapper for Hlídač státu — query the Czech public-contracts REST API v2 from the shell",
  "license": "MIT",
  "author": "Jan Hostalek",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JHostalek/hlidac-statu-cli.git"
  },
  "bugs": {
    "url": "https://github.com/JHostalek/hlidac-statu-cli/issues"
  },
  "homepage": "https://github.com/JHostalek/hlidac-statu-cli#readme",
  "keywords": [
    "hlidac-statu",
    "czech",
    "transparency",
    "public-contracts",
    "open-data",
    "cli",
    "rest-api",
    "developer-tools"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "hs": "./dist/hs.js"
  },
  "files": [
    "dist/hs.js"
  ],
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile dist/hs",
    "build:npm": "bun build src/cli.ts --outfile dist/hs.js --target node",
    "build:all": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/hs-linux-x64 && bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile dist/hs-linux-arm64 && bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/hs-darwin-x64 && bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/hs-darwin-arm64 && bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/hs-windows-x64.exe",
    "dev": "bun --watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "smoke:node": "bun scripts/smoke-node.ts",
    "openapi:sync": "bun scripts/openapi.ts sync",
    "openapi:check": "bun scripts/openapi.ts check",
    "openapi:validate": "bun scripts/openapi.ts validate"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.10",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "js-yaml": "4.3.0"
  }
}
