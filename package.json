{
  "name": "hlidac-statu-cli",
  "version": "0.3.0",
  "private": true,
  "description": "CLI wrapper for Hlídač státu — query the Czech public-contracts REST API v2 from the shell",
  "license": "MIT",
  "author": "Jan Hostalek",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JHostalek/hlidac-statu-cli.git"
  },
  "bugs": {
    "url": "https://github.com/JHostalek/hlidac-statu-cli/issues"
  },
  "homepage": "https://github.com/JHostalek/hlidac-statu-cli#readme",
  "keywords": [
    "hlidac-statu",
    "czech",
    "transparency",
    "public-contracts",
    "open-data",
    "cli",
    "rest-api",
    "developer-tools"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile dist/hs",
    "dev": "bun --watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "openapi:sync": "bun scripts/openapi.ts sync",
    "openapi:check": "bun scripts/openapi.ts check",
    "openapi:validate": "bun scripts/openapi.ts validate"
  },
  "dependencies": {
    "@effect/cli": "^0.76.0",
    "@effect/platform": "^0.97.0",
    "@effect/platform-bun": "^0.91.0",
    "@effect/printer": "^0.50.0",
    "@effect/printer-ansi": "^0.50.0",
    "effect": "^3.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^24.13.3",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.10",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "js-yaml": "4.3.0"
  }
}
